<?xml version="1.0"?>
<launch>
  <!-- Set GZ_SIM_RESOURCE_PATH so Gazebo can find the robot meshes and files -->
  <set_env name="GZ_SIM_RESOURCE_PATH" value="$(find-pkg-share my_robot_description)/..:$(env GZ_SIM_RESOURCE_PATH '')" />

  <!-- Start Gazebo Sim Server and Client with the empty world -->
  <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
    <arg name="gz_args" value="-r $(find-pkg-share my_robot_gazebo)/worlds/empty.sdf --render-engine ogre"/>
  </include>

  <!-- Start Parameter Bridge for clock topic -->
  <node pkg="ros_gz_bridge" exec="parameter_bridge" name="ros_gz_bridge"
        args="--config-file $(find-pkg-share my_robot_gazebo)/config/bridge.yaml" />
</launch>
